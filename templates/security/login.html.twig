{% extends 'base.html.twig' %}

{% block title %}Log in!
{% endblock %}

{% block body %}
	<form method="post" class="flex flex-col justify-center items-center h-screen ">
		{% if error %}
			<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
		{% endif %}

		{% if app.user %}
			<div class="mb-3">
				You are logged in as
				{{ app.user.userIdentifier }},
				<a href="{{ logout_path() }}">Logout</a>
			</div>
		{% endif %}
		<div class=" flex flex-col gap-5 sm:w-1/2 md:w-1/3" >

			<div class="flex flex-col items-center gap-3 ">
				<img src="{{ asset('imagenes/Icon.png') }}" alt="icon.png">
				<h1 class="font-bold text-3xl">Connectez-vous</h1>
				<p>Ou
					<a href="{{path('app_register')}}" class="link-color-primary ">créez un compte gratuitement</a>
				</p>
			</div>
			<div class="flex flex-col bg-white card-box-shadow gap-3 py-8 px-10">
				<label for="inputEmail" class="label-style">Adresse Email</label>
				<input type="email" value="{{ last_username }}" class="input-style mb-5" name="email" id="inputEmail" class="form-control" autocomplete="email" placeholder="contact@entreprise.fr" required autofocus>
				<label for="inputPassword" class="label-style">Mot de passe</label>
				<input type="password" name="password" id="inputPassword" class="form-control input-style" autocomplete="current-password" placeholder="password" required>
				<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
			<div class="checkbox mb-3">
				<label>
					<input type="checkbox" name="_remember_me">
					Remember me
				</label>
			</div>

			<button class="btn-primary bg-color-primary " type="submit">
				Se connecter
			</button>
			</div>
		</div>

	</form>
{% endblock %}
