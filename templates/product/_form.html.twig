{{ form_start(form, {'attr': {class:'flex justify-center px-4 md:px-0'}}) }}
<div class="flex flex-col bg-white card-box-shadow gap-5 py-6 px-5 md:py-8 md:px-10 w-full md:w-1/3">
	<div class="flex justify-between items-start">
		{% if app.request.attributes.get('_route') == 'app_product_new' %}
			<p class="font-bold text-lg  md:text-xl">Nouveau produit</p>
		{% else %}
			<div class="flex flex-col gap-1">
				<p class="font-bold text-lg md:text-xl">Produit - Développement Web</p>
				<p class="text-[#101828] font-bold text-sm md:text-base">Modifier un produit</p>
			</div>
		{% endif %}
		<a href="{{ path('app_product_index') }}" class="text-gray-500 hover:text-gray-900 ml-4">X</a>
	</div>

	<div class="flex flex-col gap-1">
		<label for="{{ form.name.vars.id }}" class="label-style">Nom</label>
		{{ form_widget(form.name, {'attr': {class: 'input-style w-full'}}) }}
	</div>

	<div class="flex flex-col gap-1">
		<label for="{{ form.description.vars.id }}" class="label-style">Description</label>
		{{ form_widget(form.description, {'attr': {class: 'input-style w-full max-h-25 resize-none'}}) }}
	</div>

	<div class="flex flex-col md:flex-row gap-4 md:gap-5">
		<div class="flex flex-col gap-1 flex-1">
			<label for="{{ form.price.vars.id }}" class="label-style">Prix</label>
			{{ form_widget(form.price, {'attr': {class: 'input-style w-full'}}) }}
		</div>

		<div class="flex flex-col gap-1 flex-1">
			<label for="{{ form.unit.vars.id }}" class="label-style">Unité</label>
			<div class="relative">
				{{ form_widget(form.unit, {'attr': {class: 'input-style w-full appearance-none pr-8 cursor-pointer'}}) }}
				<i class="fa-solid fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
			</div>
		</div>
	</div>

	<div class="flex flex-col-reverse md:flex-row md:justify-end gap-3 pt-2">
		<a href="{{ path('app_product_index') }}" class="text-center text-gray-900 text-base rounded-lg py-2.5 px-5 border border-[#D1D5DC] shadow-[0px_1px_2px_-1px_rgba(0,0,0,0.1),0px_1px_3px_0px_rgba(0,0,0,0.1)]">Annuler</a>
		<button class="btn-primary bg-color-primary">{{ button_label|default('Enregistrer') }}</button>
	</div>

</div>
{{ form_end(form) }}
