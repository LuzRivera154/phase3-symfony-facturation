{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="flex h-screen overflow-hidden">
	<twig:Sidebar/>
	<div class="flex-1 overflow-y-auto p-4 md:p-10 flex flex-col gap-8">

		<div class="flex items-center gap-4">
			<button class="md:hidden text-gray-600 text-xl" onclick="toggleSidebar()">
				<i class="fa-solid fa-bars"></i>
			</button>
			<h1 class="text-2xl font-bold">Dashboard</h1>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
			<div class="bg-white card-box-shadow rounded-xl p-4 md:p-5 flex flex-col gap-3">
				<img src="{{ asset('imagenes/Container.png') }}" alt="" class="w-10">
				<p class="text-sm text-gray-500">Chiffre d'affaires (Payé)</p>
				<p class="text-xl md:text-2xl font-bold">0 €</p>
			</div>
			<div class="bg-white card-box-shadow rounded-xl p-4 md:p-5 flex flex-col gap-3">
				<img src="{{ asset('imagenes/icon-factura.png') }}" alt="" class="w-10">
				<p class="text-sm text-gray-500">Factures en attente de paiement</p>
				<p class="text-xl md:text-2xl font-bold">0</p>
			</div>
			<div class="bg-white card-box-shadow rounded-xl p-4 md:p-5 flex flex-col gap-3">
				<img src="{{ asset('imagenes/icon-client.png') }}" alt="" class="w-10">
				<p class="text-sm text-gray-500">Total Clients</p>
				<p class="text-xl md:text-2xl font-bold">0</p>
			</div>
			<div class="bg-white card-box-shadow rounded-xl p-4 md:p-5 flex flex-col gap-3">
				<img src="{{ asset('imagenes/icon-produit.png') }}" alt="" class="w-10">
				<p class="text-sm text-gray-500">Total Produits</p>
				<p class="text-xl md:text-2xl font-bold">0</p>
			</div>
		</div>

		<div>
			<p>graficos</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
			<a href="" class="bg-white card-box-shadow rounded-xl p-5 flex justify-between item_hover items-center hover:shadow-md transition">
				<div>
					<p class="font-semibold">Créer une facture</p>
					<p class="text-sm text-gray-500">Nouvelle prestation</p>
				</div>
				<i class="fa-solid fa-arrow-right"></i>
			</a>
			<a href="" class="bg-white card-box-shadow rounded-xl p-5 flex justify-between item_hover items-center hover:shadow-md transition">
				<div>
					<p class="font-semibold">Ajouter un client</p>
					<p class="text-sm text-gray-500">Gérer le répertoire</p>
				</div>
				<i class="fa-solid fa-arrow-right text-gray-400"></i>
			</a>
			<a href="" class="bg-white card-box-shadow rounded-xl p-5 flex justify-between item_hover items-center hover:shadow-md transition">
				<div>
					<p class="font-semibold">Créer un produit / service</p>
					<p class="text-sm text-gray-500">Enrichir le catalogue pour rédiger rapidement vos factures</p>
				</div>
				<i class="fa-solid fa-arrow-right text-gray-400"></i>
			</a>
			<a href="" class="bg-white card-box-shadow rounded-xl p-5 flex justify-between item_hover items-center hover:shadow-md transition">
				<div>
					<p class="font-semibold">Relancer tous les clients</p>
					<p class="text-sm text-gray-500">Envoyer un mail à tout les clients en retard de paiement</p>
				</div>
				<i class="fa-solid fa-arrow-right text-gray-400"></i>
			</a>
		</div>

	</div>
</div>
{% endblock %}
