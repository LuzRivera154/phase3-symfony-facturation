{% extends 'base.html.twig' %}

{% block title %}Facture
	{{ invoice.number }}
{% endblock %}

{% block body %}
	<div class="flex gap-7 h-screen overflow-hidden">
		<twig:Sidebar/>
		<div class="flex flex-col flex-1 gap-6 px-4 md:pr-8 md:pl-0 mt-6 md:mt-12 overflow-y-auto">

			<div class="flex items-center gap-3">
				<button class="md:hidden text-gray-600 text-xl" onclick="toggleSidebar()">
					<i class="fa-solid fa-bars"></i>
				</button>
				<a href="{{ path('app_invoice_index') }}" class="text-gray-500 hover:text-gray-700 flex items-center gap-1 text-sm">
					<i class="fa-solid fa-arrow-left"></i>
					Retour aux factures
				</a>
			</div>

			<div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
				<div class="flex items-center gap-3">
					<h1 class="text-2xl font-bold">Facture
						{{ invoice.number }}</h1>
					{% set statusConfig = {
					'draft':           {color: 'text-gray-600 bg-gray-100',    icon: 'fa-clock',  label: 'Brouillon'},
					'pending_payment': {color: 'text-yellow-700 bg-yellow-100', icon: 'fa-clock',  label: 'En attente'},
					'paid':            {color: 'text-green-700 bg-green-100',   icon: 'fa-check',  label: 'Payé'},
				} %}
					{% set config = statusConfig[invoice.status.value] %}
					<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium {{ config.color }}">
						<i class="fa-solid {{ config.icon }}"></i>
						{{ config.label }}
					</span>
				</div>
				<div class="flex gap-3">
					{% if invoice.status.value == 'draft' %}
						<form method="post" action="{{ path('app_invoice_validate', {'id': invoice.id}) }}">
							<button type="submit" class="btn-primary bg-color-primary flex items-center gap-2">
								<i class="fa-solid fa-check"></i> Valider la facture
							</button>
						</form>
						<form method="post" action="{{ path('app_invoice_delete', {'id': invoice.id}) }}" onsubmit="return confirm('Supprimer cette facture ?');">
							<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invoice.id) }}">
							<button type="submit" class="btn-secondary bg-white border border-red-200 text-red-500 flex items-center gap-2">
								<i class="fa-solid fa-trash"></i> Supprimer
							</button>
						</form>
					{% elseif invoice.status.value == 'pending_payment' %}
						<button class="btn-secondary bg-white border border-gray-200 flex items-center gap-2">
							<i class="fa-solid fa-file-pdf"></i> PDF
						</button>
						<button class="btn-secondary bg-white border border-gray-200 flex items-center gap-2">
							<i class="fa-solid fa-paper-plane"></i> Envoyer
						</button>
						<form method="post" action="{{ path('app_invoice_validate', {'id': invoice.id}) }}">
							<button type="submit" class="py-2 px-3.5 border border-green-500 cursor-pointer rounded-xl bg-green-200 flex items-center gap-2 hover:bg-green-400">
								<span class="text-2xl">€</span> Valider le paiement
							</button>
						</form>
					{% else %}
						<button class="btn-secondary bg-white border border-gray-200 flex items-center gap-2">
							<i class="fa-solid fa-file-pdf"></i> PDF
						</button>
						<button class="btn-secondary bg-white border border-gray-200 flex items-center gap-2">
							<i class="fa-solid fa-paper-plane"></i> Envoyer
						</button>
					{% endif %}
				</div>
			</div>

			<p class="text-gray-500 text-sm">Date :
				{{ invoice.createdAt ? invoice.createdAt|date('d/m/Y') : '' }}</p>

			<div class="bg-white card-box-shadow rounded-xl p-8 flex flex-col gap-8">

				<div class="flex justify-between">
					<div class="flex flex-col gap-1">
						{% if invoice.user %}
							<p class="font-bold text-lg">{{ invoice.user.companyName|capitalize }}</p>
							<p class="text-gray-500 text-sm">{{ invoice.user.firstName }}
								{{ invoice.user.lastName }}</p>
							<p class="text-gray-500 text-sm">{{ invoice.user.email }}</p>
						{% endif %}
					</div>
					<div class="text-right">
						<p class="font-bold text-xl text-gray-700">FACTURE</p>
						<p class="text-gray-500 text-sm">N°
							{{ invoice.number }}</p>
						<p class="text-gray-500 text-sm">Date :
							{{ invoice.createdAt ? invoice.createdAt|date('d/m/Y') : '' }}</p>
					</div>
				</div>

				{% if invoice.client %}
					<div class="bg-gray-50 rounded-xl p-7 self-end flex flex-col gap-1 w-1/2  ">
						<p class="text-xs text-gray-400 uppercase mb-2">Facturé à</p>
						<p class="font-semibold text-gray-800">{{ invoice.client.name }}</p>
						{% if invoice.client.address %}
							<p class="text-gray-500 text-sm">{{ invoice.client.address }}</p>
						{% endif %}
						{% if invoice.client.email %}
							<p class="text-gray-500 text-sm">{{ invoice.client.email }}</p>
						{% endif %}
						{% if invoice.client.siret %}
							<p class="text-gray-500 text-sm">SIRET :
								{{ invoice.client.siret }}</p>
						{% endif %}
					</div>
				{% endif %}

				<table class="w-full text-sm">
					<thead>
						<tr class="border-b border-gray-600">
							<th class="text-left font-semibold text-gray-700 py-3">Description</th>
							<th class="text-right font-semibold text-gray-700 py-3">Qté</th>
							<th class="text-right font-semibold text-gray-700 py-3">Prix Unitaire</th>
							<th class="text-right font-semibold text-gray-700 py-3">Total TTC</th>
						</tr>
					</thead>
					<tbody>
						{% for item in invoice.invoiceItems %}
							<tr class="border-b border-gray-50">
								<td class="py-4">
									<p class="font-medium text-gray-800">{{ item.product.name }}</p>
									{% if item.product.description %}
										<p class="text-gray-600 text-xs">{{ item.product.description }}</p>
									{% endif %}
								</td>
								<td class="py-4 text-right text-gray-700">{{ item.quantity }}</td>
								<td class="py-4 text-right text-gray-700">{{ item.product.price }}
									€</td>
								<td class="py-4 text-right font-medium text-gray-800">{{ item.product.price * item.quantity }}
									€</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>

				<div class="flex flex-col gap-2 self-end w-64">
					<div class="flex justify-between text-gray-500 text-sm">
						<span>Total HT</span>
						<span>{{ invoice.totalTtc }}
							€</span>
					</div>
					<div class="flex justify-between font-bold text-gray-800 text-base border-t-2 border-gray-800 pt-2">
						<span>Total TTC</span>
						<span>{{ invoice.totalTtc }}
							€</span>
					</div>
					<p class="text-xs text-gray-400 text-right">TVA non applicable, art. 293 B du CGI</p>
				</div>
				{% if invoice.user and invoice.user.cgv %}
					<div class="border-t border-gray-100 pt-4">
						<p class="text-xs text-gray-400 font-medium mb-1">Conditions de paiement</p>
						<p class="text-xs text-gray-500">{{ invoice.user.cgv }}</p>
					</div>
				{% endif %}
				<p>Conditions de paiement</p>
				{% if invoice.client and invoice.client.rib %}
					<div class="bg-gray-100 rounded-lg p-4">
						<p class="text-xs text-gray-500 font-medium mb-1">Coordonnées bancaires pour le paiement :</p>
						<p class="text-xs text-gray-700 font-medium">{{ invoice.client.rib }}</p>
					</div>
				{% endif %}

			</div>
		</div>
	</div>
{% endblock %}
