{% extends 'base.html.twig' %}

{% block title %}Modifier la facture{% endblock %}

{% block body %}
	<div class="flex gap-7 h-screen overflow-hidden">
		<twig:Sidebar/>
		<div class="flex flex-col flex-1 gap-8 md:gap-10 px-4 md:pr-8 md:pl-0 mt-6 md:mt-12 overflow-y-auto">

			<div class="flex flex-col gap-5">
				<a href="{{ path('app_invoice_index') }}" class="text-[#6A7282] flex gap-3 items-center">
					<i class="fa-solid fa-arrow-left"></i>
					Retour aux factures
				</a>
				<div class="flex items-center gap-3">
					<button class="md:hidden text-gray-600 text-xl" onclick="toggleSidebar()">
						<i class="fa-solid fa-bars"></i>
					</button>
					<h1 class="font-bold text-xl md:text-2xl">Modifier la facture</h1>
				</div>
			</div>

			<div>
				{{ include('invoice/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
			</div>

		</div>
	</div>
{% endblock %}
