<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<script src="https://cdn.tailwindcss.com"></script>
		<link rel="stylesheet" href="pdf.css">
		<title>Facture
			{{ invoice.number }}</title>
	</head>
	<body class="bg-white p-10 flex flex-col gap-8 min-h-screen">

		<div class="flex justify-between items-start">
			<div class="flex flex-col gap-1">
				{% if invoice.user %}
					<p class="font-bold text-lg text-gray-800">{{ invoice.user.companyName|capitalize }}</p>
					<p class="text-gray-500 text-sm">{{ invoice.user.firstName }}
						{{ invoice.user.lastName }}</p>
					<p class="text-gray-500 text-sm">{{ invoice.user.email }}</p>
				{% endif %}
			</div>
			<div class="text-right">
				<p class="font-bold text-xl text-gray-700">FACTURE</p>
				<p class="text-gray-500 text-sm">N°
					{{ invoice.number }}</p>
				<p class="text-gray-500 text-sm">Date :
					{{ invoice.createdAt ? invoice.createdAt|date('d/m/Y') : '' }}</p>
				<p class="text-gray-700 text-sm">{{ invoice.status.label }}</p>
			</div>
		</div>

		{% if invoice.client %}
			<div class="bg-gray-50 rounded-xl p-6 self-end flex flex-col gap-1 w-1/2">
				<p class="text-xs text-gray-400 uppercase mb-2">Facturé à</p>
				<p class="font-semibold text-gray-800">{{ invoice.client.name }}</p>
				{% if invoice.client.address %}
					<p class="text-gray-500 text-sm">{{ invoice.client.address }}</p>
				{% endif %}
				{% if invoice.client.email %}
					<p class="text-gray-500 text-sm">{{ invoice.client.email }}</p>
				{% endif %}
				{% if invoice.client.siret %}
					<p class="text-gray-500 text-sm">SIRET :
						{{ invoice.client.siret }}</p>
				{% endif %}
			</div>
		{% endif %}

		<table class="w-full text-sm">
			<thead>
				<tr class="border-b border-gray-600">
					<th class="text-left font-semibold text-gray-700 py-3">Description</th>
					<th class="text-right font-semibold text-gray-700 py-3">Qté</th>
					<th class="text-right font-semibold text-gray-700 py-3">Prix Unitaire</th>
					<th class="text-right font-semibold text-gray-700 py-3">Total TTC</th>
				</tr>
			</thead>
			<tbody>
				{% for item in invoice.invoiceItems %}
					<tr class="border-b border-gray-100">
						<td class="py-4">
							<p class="font-medium text-gray-800">{{ item.product.name }}</p>
							{% if item.product.description %}
								<p class="text-gray-500 text-xs mt-1">{{ item.product.description }}</p>
							{% endif %}
						</td>
						<td class="py-4 text-right text-gray-700">{{ item.quantity }}</td>
						<td class="py-4 text-right text-gray-700">{{ item.product.price }}
							€</td>
						<td class="py-4 text-right font-medium text-gray-800">{{ item.product.price * item.quantity }}
							€</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		<div class="mt-auto flex flex-col gap-6">

			<div class="flex flex-col gap-2 self-end w-64">
				<div class="flex justify-between text-gray-500 text-sm py-1">
					<span>Total HT</span>
					<span>{{ invoice.totalTtc }}
						€</span>
				</div>
				<div class="flex justify-between font-bold text-gray-800 text-base border-t-2 border-gray-800 pt-2">
					<span>Total TTC</span>
					<span>{{ invoice.totalTtc }}
						€</span>
				</div>
				<p class="text-xs text-gray-400 text-right mt-1">TVA non applicable, art. 293 B du CGI</p>
			</div>

			{% if invoice.user and invoice.user.cgv %}
				<div class="border-t border-gray-100 pt-4">
					<p class="text-xs text-gray-400 font-medium mb-1 uppercase">Conditions de paiement</p>
					<p class="text-xs text-gray-500">{{ invoice.user.cgv }}</p>
				</div>
			{% endif %}


			{% if invoice.client and invoice.client.rib %}
				<div class="bg-gray-100 rounded-lg p-4">
					<p class="text-xs text-gray-500 font-medium mb-1">Coordonnées bancaires pour le paiement :</p>
					<p class="text-xs text-gray-700 font-medium">{{ invoice.client.rib }}</p>
				</div>
			{% endif %}

		</div>

	</body>
</html>
