{% extends 'base.html.twig' %}

{% block title %}New Client
{% endblock %}

{% block body %}
	<div class="flex  gap-7 h-screen overflow-hidden">
		<twig:Sidebar/>
		<div class="flex flex-col flex-1 gap-6 md:gap-10 mt-6 md:mt-12 overflow-y-auto px-4 md:pr-6 md:pl-0">
			<div>

				<h1 class="font-bold text-xl uppercase text-center md:text-2xl">Ajouter un nouveau client</h1>

				{{ include('client/_form.html.twig') }}
			</div>
			<div class="flex flex-col gap-4">
				<h2 class="font-bold text-center text-gray-600 text-xl md:text-2xl">Clients existant</h2>
				<div class="bg-white rounded-xl card-box-shadow overflow-hidden border border-gray-100">
					<div class="overflow-x-auto">
						<table class="w-full text-sm">
							<thead class="bg-[#F9FAFB]">
								<tr class="border-b border-black">
									<th class="text-left font-semibold text-gray-900 px-4 md:px-6 py-4">Nom</th>
									<th class="text-left font-semibold text-gray-900 px-4 md:px-6 py-4 hidden md:table-cell">Contact</th>
									<th class="text-left font-semibold text-gray-900 px-4 md:px-6 py-4 hidden md:table-cell">Adresse</th>
									<th class="text-right font-semibold text-gray-900 px-4 md:px-6 py-4">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for client in clients %}
									<tr class="border-b border-gray-50 hover:bg-gray-50 transition">
										<td class="px-4 md:px-6 py-4 font-medium text-gray-800">{{ client.name }}</td>
										<td class="px-4 md:px-6 py-4 hidden md:table-cell">
											<p>{{ client.email }}</p>
											<p class="text-gray-500">{{ client.phone }}</p>
										</td>
										<td class="px-4 md:px-6 py-4 text-gray-500 hidden md:table-cell">{{ client.address }}</td>
										<td class="px-4 md:px-6 py-4 text-right">
											<div class="flex justify-end gap-3">
												<a href="{{ path('app_client_edit', {'id': client.id}) }}" class="text-blue-400 hover:text-blue-600 transition">
													<i class="fa-solid fa-pen"></i>
												</a>
												<form method="post" action="{{ path('app_client_delete', {'id': client.id}) }}" onsubmit="return confirm('Supprimer ce client ?');" class="inline">
													<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
													<button type="submit" class="text-red-400 hover:text-red-600 transition cursor-pointer bg-transparent border-none">
														<i class="fa-solid fa-trash"></i>
													</button>
												</form>
											</div>
										</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="4" class="px-6 py-10 text-center text-gray-400">Aucun client trouvé</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>

		</div>

	</div>
{% endblock %}
